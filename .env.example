# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=AQ.Ab8RN6IFajpEI-V7c7nC46X6qdHsIf3JZwKQRSfaSADVTzaYXQ

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local example variables (edit for your local dev only)
# Path to Google service account JSON used by Google client libraries
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Gemini / Google GenAI API key (if using API key auth)
GEMINI_API_KEY=your-gemini-api-key-here

# JWT secret used by the dev server for mock auth
JWT_SECRET=change-this-to-a-secure-string

# Vercel flag (optional): when set, the app uses /tmp for persistence
# VERCEL=true
